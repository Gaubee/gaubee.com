# 前端环境变量（Vite 注入，需 VITE_ 前缀）

# Worker 的基础 URL。
# 本地开发：留空（VITE_AUTH_BASE=）。前端与 Worker 经 vite server.proxy 同源转发
#   （见 vite.config.ts 的 server.proxy），fetch('/auth/me') 走相对路径，cookie 同域无需 CORS。
#   前提：本地走 portless（pnpm dev → https://gaubee.com.localhost）+ wrangler dev（localhost:8787）。
# 生产环境：填 Cloudflare Worker 域名（前端跨域直连），如 https://gaubee-auth-production.gaubeebangeel.workers.dev
VITE_AUTH_BASE=

# 应急禁用 Service Worker（仅生产构建生效；dev 下 SW 本就不注册）
# 设为 true 后重新 build，可临时关闭 /pages 加速缓存
# VITE_DISABLE_SW=true

# Worker 的环境变量（在 worker/.dev.vars 或 wrangler secret 配置，不提交）：
# GITHUB_CLIENT_ID     - GitHub OAuth App 的 Client ID
# GITHUB_CLIENT_SECRET - GitHub OAuth App 的 Client Secret
# APP_ORIGIN           - 静态站点 origin（OAuth 成功后重定向目标 + 生产 CORS 白名单）。
#                        本地：https://gaubee.com.localhost（portless）；生产：https://gaubee.com
# WORKER_ORIGIN        - Worker 自身 origin（构造 OAuth redirect_uri）。
#                        本地：https://gaubee.com.localhost（经 vite proxy 回流）；生产：Worker 域名

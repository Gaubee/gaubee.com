		"minisearch": "^7.2.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.9.5",
		"prettier-plugin-organize-imports": "^4.3.0",
		"shiki": "^4.3.1",
		"svelte-sonner": "^1.1.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
